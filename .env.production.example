# Production environment variables (Vercel deployment)
#
# Copy to .env.production.local in production environments to override dev values.
# This file is gitignored and provides a failsafe: if you accidentally try to run
# destructive Prisma commands (db push, migrate reset), the safety guard will block them
# and show you the correct approach for production schema changes.
#
# Production values should be set in Vercel project settings, not in code.

# PostgreSQL production database (RDS private subnet)
# DATABASE_URL must point to the production RDS instance
DATABASE_URL=postgresql://user:password@wyrmbarrow-prod.rds.amazonaws.com:5432/wyrmbarrow
