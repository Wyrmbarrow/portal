// Wyrmbarrow Portal — Prisma Schema (read-only views of the game database)
// The portal reads from the same PostgreSQL instance as the Evennia server.
// It does NOT write game state — all mutations go through the Evennia REST API.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ── Human patron accounts (Google OAuth) ─────────────────────────────────────

model Patron {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  googleId        String   @unique @map("google_id")
  createdAt       DateTime @default(now()) @map("created_at")

  registrationHashes RegistrationHash[]

  @@map("portal_patrons")
}

model RegistrationHash {
  id             String   @id @default(cuid())
  hash           String   @unique
  patronId       String   @map("patron_id")
  patronGoogleId String   @map("patron_google_id")
  createdAt      DateTime @default(now()) @map("created_at")

  patron Patron @relation(fields: [patronId], references: [id])

  @@map("portal_registration_hashes")
}

// ── Character-patron linkage (portal-owned, Evennia writes via raw SQL) ───────

model PatronCharacter {
  id             String   @id @default(cuid())
  patronGoogleId String   @map("patron_google_id")
  characterId    BigInt   @map("character_id")
  characterName  String   @map("character_name")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([characterId])
  @@index([patronGoogleId])
  @@map("portal_patron_characters")
}

model FeedbackNote {
  id             String   @id @default(cuid())
  journalEntryId Int      @unique @map("journal_entry_id")
  status         String   @default("new")
  note           String?
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedBy      String   @map("updated_by")

  @@map("portal_feedback_notes")
}

// ── Read-only views of Evennia game data ─────────────────────────────────────
// Note: objects_objectdb (Evennia's Character model) is intentionally NOT mapped
// here — its column names don't match what Prisma expects on the production DB.
// Use PatronCharacter for character lookups instead.

model JournalEntry {
  id          Int      @id @default(autoincrement())
  characterId Int      @map("character_id")
  entryType   String   @map("entry_type")
  content     String
  wordCount   Int      @map("word_count")
  createdAt    DateTime @default(now()) @map("created_at")
  oocSubtype   String?  @map("ooc_subtype")
  locationName String   @map("location_name") @default("")

  @@map("journal_journalentry")
}

model CharacterSheet {
  id           BigInt   @id @default(autoincrement())
  characterId  Int      @unique @map("character_id")
  data         Json
  updatedAt    DateTime @map("updated_at")

  @@map("wyrmbarrow_character_sheets")
}

// Note: hub pressure is stored as an Evennia Script Attribute (not a direct table).
// The portal reads it via the Evennia REST API, not via Prisma.
