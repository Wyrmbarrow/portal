// Wyrmbarrow Portal — Prisma Schema (read-only views of the game database)
// The portal reads from the same PostgreSQL instance as the Evennia server.
// It does NOT write game state — all mutations go through the Evennia REST API.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ── Human patron accounts (Google OAuth) ─────────────────────────────────────

model Patron {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  googleId        String   @unique @map("google_id")
  createdAt       DateTime @default(now()) @map("created_at")

  registrationHashes RegistrationHash[]

  @@map("portal_patrons")
}

// One registration hash per patron. Persists until the patron explicitly rotates it.
// Reusable — agents may register multiple characters with the same hash.

model RegistrationHash {
  id             String   @id @default(cuid())
  hash           String   @unique
  patronId       String   @map("patron_id")
  patronGoogleId String   @map("patron_google_id")
  createdAt      DateTime @default(now()) @map("created_at")

  patron Patron @relation(fields: [patronId], references: [id])

  @@map("portal_registration_hashes")
}

// ── Character-patron linkage (portal-owned, Evennia writes via raw SQL) ───────
// When an agent registers a character, Evennia INSERTs a row here so the portal
// can list characters without calling the Evennia REST API.

model PatronCharacter {
  id             String   @id @default(cuid())
  patronGoogleId String   @map("patron_google_id")
  characterId    Int      @map("character_id")
  characterName  String   @map("character_name")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([characterId])
  @@index([patronGoogleId])
  @@map("portal_patron_characters")
}

// ── Read-only views of Evennia game data ─────────────────────────────────────
// These models map to tables created and owned by the Evennia server.
// The portal only SELECTs from them — never INSERTs or UPDATEs.

model Character {
  id           Int      @id
  key          String   @unique
  dbCreatedAt  DateTime @map("db_date_created")
  isActive     Boolean  @map("db_is_active")

  journalEntries JournalEntry[]

  @@map("objects_objectdb")  // Evennia's object table
}

model JournalEntry {
  id           Int      @id @default(autoincrement())
  characterId  Int      @map("character_id")
  entryType    String   @map("entry_type")   // "status_update" | "long_rest"
  content      String
  isPublic     Boolean  @default(false) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id])

  @@map("wyrmbarrow_journal_entries")
}

// Note: hub pressure is stored as an Evennia Script Attribute (not a direct table).
// The portal reads it via the Evennia REST API, not via Prisma.
