# Copy to .env.local and fill in values

# Dev server port (default: 3000)
PORT=3000

# Google OAuth (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
AUTH_SECRET=change_me_to_a_long_random_string

# Evennia server REST API
WYRMBARROW_API_URL=http://localhost:4001
WYRMBARROW_API_TOKEN=change_me_to_match_WYRMBARROW_INTERNAL_TOKEN

# PostgreSQL (same DB as the Evennia server)
DATABASE_URL=postgresql://wyrmbarrow:password@localhost:5432/wyrmbarrow

# Admin portal — only this email can access /admin
ADMIN_EMAIL=
